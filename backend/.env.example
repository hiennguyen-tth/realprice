# =============================================
# RealPrice Backend — Environment Variables
# Copy to .env and fill in your values
# =============================================

# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=realprice
DB_USER=realprice_user
DB_PASSWORD=your_db_password_here
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL_DEFAULT=300

# JWT
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_EXPIRY_MINUTES=5
OTP_LENGTH=6
# Set to 'true' to bypass real SMS in development (log OTP to console)
OTP_DEV_BYPASS=true

# AWS S3
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_BUCKET_NAME=realprice-images
S3_PRESIGNED_URL_EXPIRY=600

# GEMINI (for Chatbot)
GEMINI_API_KEY=AIzaSyATg34Jx7LZOt2hRfMtU2ohxljud30s17A
GEMINI_MODEL=gemini-2.0-flash

# SMS Provider (for OTP)
SMS_PROVIDER=esms
ESMS_API_KEY=your_esms_api_key
ESMS_SECRET_KEY=your_esms_secret_key
ESMS_BRAND_NAME=RealPrice

# VNPay
VNPAY_TMN_CODE=your_vnpay_tmn_code
VNPAY_HASH_SECRET=your_vnpay_hash_secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/api/payment/vnpay/callback

# MoMo
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_RETURN_URL=http://localhost:3000/api/payment/momo/callback
MOMO_NOTIFY_URL=http://localhost:3000/api/payment/momo/notify

# BullMQ
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=

# Boost Pricing (VND)
BOOST_PRICE_3DAYS=99000
BOOST_PRICE_7DAYS=199000
BOOST_PRICE_30DAYS=599000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# Logging
LOG_LEVEL=debug
LOG_FORMAT=dev

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:8080
