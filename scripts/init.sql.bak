-- ============================================================
-- RealPrice Database Initialization Script
-- PostgreSQL 15 + PostGIS 3.3
-- ============================================================

-- Enable extensions
CREATE EXTENSION IF NOT EXISTS postgis;
CREATE EXTENSION IF NOT EXISTS pg_trgm;
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS pgcrypto;

-- ============================================================
-- Users
-- ============================================================
CREATE TABLE IF NOT EXISTS users (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  email TEXT NOT NULL UNIQUE,
  name TEXT NOT NULL,
  password_hash TEXT NOT NULL,
  avatar TEXT,
  phone TEXT,
  plan TEXT NOT NULL DEFAULT 'free' CHECK (plan IN ('free', 'pro', 'enterprise')),
  is_active BOOLEAN DEFAULT TRUE,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- ============================================================
-- Lands
-- ============================================================
CREATE TABLE IF NOT EXISTS lands (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  address TEXT NOT NULL,
  district TEXT NOT NULL,
  city TEXT NOT NULL,
  street TEXT,
  slug_district TEXT NOT NULL,
  slug_street TEXT NOT NULL,
  location GEOMETRY(Point, 4326) NOT NULL,
  boundary GEOMETRY(Polygon, 4326),
  min_price BIGINT,
  max_price BIGINT,
  avg_price BIGINT,
  price_per_m2 BIGINT,
  total_listings INT DEFAULT 0,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW(),
  UNIQUE(slug_district, slug_street)
);

CREATE INDEX IF NOT EXISTS idx_lands_location ON lands USING GIST (location);
CREATE INDEX IF NOT EXISTS idx_lands_district ON lands (district);
CREATE INDEX IF NOT EXISTS idx_lands_slug ON lands (slug_district, slug_street);

-- ============================================================
-- Listings
-- ============================================================
CREATE TABLE IF NOT EXISTS listings (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  land_id UUID REFERENCES lands(id) ON DELETE SET NULL,
  user_id UUID REFERENCES users(id) ON DELETE SET NULL,
  title TEXT NOT NULL,
  description TEXT,
  price BIGINT NOT NULL,
  area DECIMAL(10,2) NOT NULL,
  price_per_m2 BIGINT,
  listing_type TEXT NOT NULL CHECK (listing_type IN ('dat_nen','nha_pho','chung_cu','biet_thu','van_phong')),
  status TEXT NOT NULL DEFAULT 'pending' CHECK (status IN ('active','sold','expired','pending')),
  images TEXT[] DEFAULT '{}',
  address TEXT NOT NULL,
  location GEOMETRY(Point, 4326),
  contact_name TEXT,
  contact_phone TEXT,
  score INT DEFAULT 50,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_listings_land_id ON listings (land_id);
CREATE INDEX IF NOT EXISTS idx_listings_user_id ON listings (user_id);
CREATE INDEX IF NOT EXISTS idx_listings_location ON listings USING GIST (location);
CREATE INDEX IF NOT EXISTS idx_listings_status ON listings (status);
CREATE INDEX IF NOT EXISTS idx_listings_title_trgm ON listings USING GIN (title gin_trgm_ops);
CREATE INDEX IF NOT EXISTS idx_listings_created_at ON listings (created_at DESC);

-- ============================================================
-- Price History
-- ============================================================
CREATE TABLE IF NOT EXISTS price_history (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  land_id UUID REFERENCES lands(id) ON DELETE CASCADE,
  avg_price BIGINT NOT NULL,
  price_per_m2 BIGINT NOT NULL,
  total_listings INT DEFAULT 0,
  recorded_at DATE NOT NULL,
  source TEXT DEFAULT 'system'
);

CREATE INDEX IF NOT EXISTS idx_price_history_land_date ON price_history (land_id, recorded_at DESC);

-- ============================================================
-- Bank Valuations
-- ============================================================
CREATE TABLE IF NOT EXISTS bank_valuations (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  land_id UUID REFERENCES lands(id) ON DELETE CASCADE,
  bank_name TEXT NOT NULL,
  bank_code TEXT NOT NULL,
  valuation_price BIGINT NOT NULL,
  ltv_ratio DECIMAL(5,2) NOT NULL DEFAULT 70,
  interest_rate DECIMAL(5,2),
  valuation_date DATE NOT NULL,
  notes TEXT,
  vs_market_percent DECIMAL(6,2) DEFAULT 0,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_bank_valuations_land_id ON bank_valuations (land_id);

-- ============================================================
-- Heatmap Areas (pre-computed nightly)
-- ============================================================
CREATE TABLE IF NOT EXISTS heatmap_areas (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  name TEXT NOT NULL,
  district TEXT NOT NULL,
  boundary GEOMETRY(Polygon, 4326) NOT NULL,
  avg_price BIGINT NOT NULL,
  price_per_m2 BIGINT NOT NULL,
  price_level INT NOT NULL CHECK (price_level BETWEEN 1 AND 5),
  updated_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_heatmap_boundary ON heatmap_areas USING GIST (boundary);
CREATE INDEX IF NOT EXISTS idx_heatmap_district ON heatmap_areas (district);

-- ============================================================
-- Comparisons
-- ============================================================
CREATE TABLE IF NOT EXISTS comparisons (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  listing_ids UUID[] NOT NULL,
  analysis JSONB,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

-- ============================================================
-- Leads
-- ============================================================
CREATE TABLE IF NOT EXISTS leads (
  id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
  listing_id UUID REFERENCES listings(id) ON DELETE CASCADE,
  name TEXT NOT NULL,
  phone TEXT NOT NULL,
  email TEXT,
  message TEXT,
  created_at TIMESTAMPTZ DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_leads_listing_id ON leads (listing_id);

-- ============================================================
-- Saved listings (user bookmarks)
-- ============================================================
CREATE TABLE IF NOT EXISTS saved_listings (
  user_id UUID REFERENCES users(id) ON DELETE CASCADE,
  listing_id UUID REFERENCES listings(id) ON DELETE CASCADE,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  PRIMARY KEY (user_id, listing_id)
);

-- ============================================================
-- Update timestamp trigger
-- ============================================================
CREATE OR REPLACE FUNCTION update_updated_at()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER set_updated_at_users
  BEFORE UPDATE ON users
  FOR EACH ROW EXECUTE FUNCTION update_updated_at();

CREATE TRIGGER set_updated_at_lands
  BEFORE UPDATE ON lands
  FOR EACH ROW EXECUTE FUNCTION update_updated_at();

CREATE TRIGGER set_updated_at_listings
  BEFORE UPDATE ON listings
  FOR EACH ROW EXECUTE FUNCTION update_updated_at();

-- ============================================================
